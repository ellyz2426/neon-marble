      <div id="btn-lvl-31" class="lvl-btn-master" cursor="pointer"><span id="lvl-name-31" class="lvl-name-master">32</span><span id="lvl-status-31" class="lvl-status">---</span></div>
      <div id="btn-lvl-32" class="lvl-btn-master" cursor="pointer"><span id="lvl-name-32" class="lvl-name-master">33</span><span id="lvl-status-32" class="lvl-status">---</span></div>
      <div id="btn-lvl-33" class="lvl-btn-master" cursor="pointer"><span id="lvl-name-33" class="lvl-name-master">34</span><span id="lvl-status-33" class="lvl-status">---</span></div>
      <div id="btn-lvl-34" class="lvl-btn-master" cursor="pointer"><span id="lvl-name-34" class="lvl-name-master">35</span><span id="lvl-status-34" class="lvl-status">---</span></div>
      <div id="btn-lvl-35" class="lvl-btn-master" cursor="pointer"><span id="lvl-name-35" class="lvl-name-master">36</span><span id="lvl-status-35" class="lvl-status">---</span></div>
    </div>
  </div>
  <div id="btn-lvl-back" class="back-btn" cursor="pointer">
    <span class="back-text">Back</span>
  </div>
</div>
